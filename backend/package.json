{
  "name": "cs2-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "pm2:dev": "pm2 start ts-node -- src/server.ts --name \"cs2-backend-dev\" --watch",
    "pm2:prod": "pm2 start dist/server.js --name \"cs2-backend\" --watch",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3"
  }
}
